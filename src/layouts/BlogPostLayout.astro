---
import BaseLayout from "./BaseLayout.astro";
import SiteFooter from "../components/SiteFooter.astro";
import SiteNav from "../components/SiteNav.astro";
import RelatedPosts from "../components/blog/RelatedPosts.astro";
import type { CollectionEntry } from "astro:content";

interface Props {
  entry: CollectionEntry<"blog">;
  readingLabel: string;
  jsonLdInner: string[];
}

const { entry, readingLabel, jsonLdInner } = Astro.props;
const { title, description, pubDate, author, cluster, tags, relatedPosts } = entry.data;

const displayTitle = title.trim() || entry.id;
const displayDescription = description.trim();
const dateLabel = pubDate
  ? pubDate.toLocaleDateString("en-US", { year: "numeric", month: "short", day: "numeric" })
  : "Date TBD";
---

<BaseLayout
  title={displayTitle === entry.id ? `${entry.id} | peri blog` : `${displayTitle} | peri`}
  description={displayDescription || "Perimenopause education from peri."}
  canonicalPath={`/blog/${entry.id}`}
  jsonLdInner={jsonLdInner}
>
  <SiteNav />

  <article class="px-5 py-14 md:px-12 md:py-16">
    <div class="mx-auto max-w-[760px]">
      <p class="text-[11px] uppercase tracking-[0.1em] text-siena">{cluster.trim() || "Draft"}</p>
      <h1 class="mt-3 font-display text-[clamp(32px,4vw,48px)] leading-[1.1] text-umbra">
        {displayTitle}
      </h1>

      <div class="mt-6 flex flex-wrap gap-4 text-[13px] text-pizarra">
        <span>{author.trim() ? author : "Author TBD"}</span>
        <span aria-hidden="true">·</span>
        {
          pubDate ? (
            <time datetime={pubDate.toISOString()}>{dateLabel}</time>
          ) : (
            <span>{dateLabel}</span>
          )
        }
        <span aria-hidden="true">·</span>
        <span>{readingLabel}</span>
      </div>

      {
        tags.length > 0 ? (
          <ul class="mt-6 flex flex-wrap gap-2">
            {tags.map((t) => (
              <li class="rounded-full border border-[rgba(44,40,37,0.12)] px-3 py-1 text-[11px] uppercase tracking-[0.08em] text-pizarra">
                {t}
              </li>
            ))}
          </ul>
        ) : null
      }

      <div
        class="mt-10 space-y-5 text-[15px] leading-relaxed text-pizarra [&_h1]:text-umbra [&_h2]:mt-12 [&_h2]:text-[26px] [&_h2]:font-semibold [&_h2]:text-umbra [&_h3]:mt-8 [&_h3]:text-[20px] [&_h3]:font-semibold [&_h3]:text-umbra [&_a]:text-siena [&_ul]:list-disc [&_ul]:pl-6 [&_ol]:list-decimal [&_ol]:pl-6 [&_blockquote]:border-l-2 [&_blockquote]:border-siena [&_blockquote]:pl-4 [&_code]:rounded [&_code]:bg-[rgba(44,40,37,0.06)] [&_code]:px-1.5 [&_code]:py-0.5 [&_code]:text-[14px] [&_code]:text-umbra [&_pre]:rounded-[14px] [&_pre]:border [&_pre]:border-[rgba(44,40,37,0.08)] [&_pre]:bg-[rgba(44,40,37,0.04)] [&_pre]:p-4 [&_pre]:text-[14px] [&_pre]:text-umbra [&_table]:w-full [&_table]:text-left [&_table]:text-sm [&_td]:border-b [&_td]:border-[rgba(44,40,37,0.08)] [&_td]:py-2 [&_th]:border-b [&_th]:border-umbra [&_th]:py-2 [&_th]:font-medium"
      >
        <slot />
      </div>

      <aside class="mt-16 border-t border-[rgba(44,40,37,0.1)] pt-10">
        <RelatedPosts ids={relatedPosts} currentId={entry.id} />
      </aside>
    </div>
  </article>

  <SiteFooter />
</BaseLayout>
