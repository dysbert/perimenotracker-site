---
import type { CollectionEntry } from "astro:content";
import { getCollection, getEntry, render } from "astro:content";
import BlogPostLayout from "../../layouts/BlogPostLayout.astro";
import { extractJsonLdInnerHtml } from "../../lib/jsonld";
import { getReadingTime } from "../../lib/reading-time";

export async function getStaticPaths() {
  const posts = await getCollection("blog");
  return posts.map((post) => ({ params: { slug: post.id } }));
}

const slug = Astro.params.slug;
if (!slug) {
  return Astro.redirect("/blog");
}

const entry = await getEntry("blog", slug);

if (!entry || entry.collection !== "blog") {
  return Astro.redirect("/blog");
}

const blogEntry = entry as CollectionEntry<"blog">;

const { Content, remarkPluginFrontmatter } = await render(blogEntry);

const fm = remarkPluginFrontmatter && typeof remarkPluginFrontmatter === "object" ? remarkPluginFrontmatter : {};
const rawScripts = "ldJsonScripts" in fm ? fm.ldJsonScripts : undefined;

const ldJsonScripts = Array.isArray(rawScripts)
  ? rawScripts.filter((script): script is string => typeof script === "string")
  : [];

const jsonLdInner = ldJsonScripts.map((block) => extractJsonLdInnerHtml(block));
const rt = getReadingTime(blogEntry.body);
---

<BlogPostLayout entry={blogEntry} readingLabel={rt.label} jsonLdInner={jsonLdInner}>
  <Content />
</BlogPostLayout>
