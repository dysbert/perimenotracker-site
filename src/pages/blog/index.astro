---
import { getCollection } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";

const posts = await getCollection("blog");

posts.sort((a, b) => {
  const tb = (b.data.pubDate as Date | undefined)?.getTime() ?? Number.NEGATIVE_INFINITY;
  const ta = (a.data.pubDate as Date | undefined)?.getTime() ?? Number.NEGATIVE_INFINITY;
  return tb - ta;
});
---

<BaseLayout title="Blog | peri" description="Perimenopause guides and practical tracking tips from peri." canonicalPath="/blog">
  <meta slot="head" property="og:type" content="website" />

  <header
    class="sticky top-0 z-40 border-b border-[rgba(44,40,37,0.08)] bg-[rgba(245,240,232,0.92)] backdrop-blur-[12px]"
  >
    <nav class="mx-auto flex h-[52px] w-full max-w-[1100px] items-center justify-between px-5 md:px-12">
      <a href="/" class="font-display text-[18px] italic text-umbra">peri</a>
      <a href="/" class="text-[12px] font-medium uppercase tracking-[0.04em] text-pizarra hover:text-siena">Home</a>
    </nav>
  </header>

  <section class="px-5 py-16 md:px-12 md:py-20">
    <div class="mx-auto max-w-[900px]">
      <p class="text-[11px] uppercase tracking-[0.14em] text-siena">Blog</p>
      <h1 class="mt-3 font-display text-[clamp(34px,4vw,50px)] text-umbra">Perimenopause guides</h1>
      <p class="mt-4 max-w-[620px] text-[15px] leading-relaxed text-pizarra">
        Evidence-informed education to help you understand symptoms, recognize patterns, and prepare for clinician visits.
      </p>

      <div class="mt-12 grid gap-4">
        {
          posts.length === 0 ? (
            <p class="rounded-[14px] bg-[rgba(44,40,37,0.04)] p-6 text-[14px] text-pizarra">
              No posts yet. Add markdown files under <code class="text-umbra">src/content/blog/</code>.
            </p>
          ) : (
            posts.map((post) => (
              <article class="rounded-[14px] bg-[rgba(44,40,37,0.04)] p-6">
                <p class="text-[11px] uppercase tracking-[0.08em] text-siena">
                  {typeof post.data.cluster === "string" && post.data.cluster.trim() ? post.data.cluster : "Article"}
                </p>
                <h2 class="mt-2 text-[22px] font-semibold text-umbra">
                  <a class="transition-colors hover:text-siena" href={`/blog/${post.id}`}>
                    {typeof post.data.title === "string" && post.data.title.trim() ? post.data.title : post.id}
                  </a>
                </h2>
                <p class="mt-2 text-[14px] leading-relaxed text-pizarra">
                  {typeof post.data.description === "string" && post.data.description.trim()
                    ? post.data.description
                    : "Coming soon."}
                </p>
              </article>
            ))
          )
        }
      </div>
    </div>
  </section>
</BaseLayout>
