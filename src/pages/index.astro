---
import BaseLayout from "../layouts/BaseLayout.astro";

/**
 * Not used in production: `npm run build` merges the Astro blog into the Next export (`out/`).
 * For blog-only local preview run `npm run dev:astro`. The marketing site lives in Next (`app/page.tsx`; `npm run dev`).
 */
---

<BaseLayout title="peri" description="Local Astro shell only." canonicalPath="/">
  <meta slot="head" name="robots" content="noindex" />

  <main class="min-h-[40vh] px-8 py-16">
    <div class="mx-auto max-w-xl text-center">
      <p class="text-[13px] text-pizarra">
        This Astro index is only for <code class="rounded bg-[rgba(44,40,37,0.06)] px-1">astro dev</code> /
        <code class="rounded bg-[rgba(44,40,37,0.06)] px-1">dev:astro</code>. Deployed homepage comes from Next static export merged with <code>/blog</code>.
      </p>
      <div class="mt-6 flex flex-wrap justify-center gap-3">
        <a href="/blog" class="rounded-full bg-siena px-5 py-2 text-[13px] font-medium text-creta">Blog (Astro preview)</a>
      </div>
    </div>
  </main>
</BaseLayout>
