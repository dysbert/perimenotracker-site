{
  "extends": "astro/tsconfigs/strict",
  "compilerOptions": {
    "jsx": "preserve",
    "incremental": true,
    "plugins": [
      {
        "name": "next"
      }
    ]
  },
  "include": [
    ".astro/types.d.ts",
    "astro.config.ts",
    "src/**/*.astro",
    "src/**/*.ts",
    "global.d.ts",
    "next-env.d.ts",
    "app/**/*.ts",
    "app/**/*.tsx",
    "components/**/*.ts",
    "components/**/*.tsx",
    ".next/types/**/*.ts"
  ],
  "exclude": ["node_modules", "App/**", "Views/**", "Models/**", "Services/**", "ViewModels/**", "dist", "out"]
}
